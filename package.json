{
  "name": "obsidian_extension",
  "version": "1.0.0",
  "description": "A Manifest V3 Chrome extension that captures web pages and selections directly into your Obsidian vault, with a ProseMirror-powered markdown editor and optional LLM-powered tag generation.",
  "main": "background.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "esbuild sidebar/sidebar-src.js --bundle --format=iife --global-name=SidebarApp --outfile=sidebar/sidebar.js",
    "build:watch": "esbuild sidebar/sidebar-src.js --bundle --format=iife --global-name=SidebarApp --outfile=sidebar/sidebar.js --watch",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-menu": "^1.3.2",
    "prosemirror-model": "^1.25.9",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.9"
  }
}
